# dotblogs 帳號（登入 email）
BLOG_USER=

# 部落格顯示名稱（對應 MetaWeblog weblogName 欄位）
BLOG_NAME=

# 部落格子網域（dotblogs.com.tw/<BLOG_URL>）
BLOG_URL=

# MetaWeblog API 端點
BLOG_API_URL=https://dotblogs.com.tw/Api/MetaWeblog

# 密碼請用 keyring 儲存，不要放這裡：
# uv run python3 -c "import keyring; keyring.set_password('dotblogs', 'BLOG_PASSWORD', '你的密碼')"
